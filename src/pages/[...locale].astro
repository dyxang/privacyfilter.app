---
import "../styles/global.css";
import {
  i18n,
  demos,
  seo,
  localeNames,
  routeToLocale,
  localeToHtmlLang,
  localeToOgLocale,
  localeIsRtl
} from "../lib/i18n.js";

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    { params: { locale: "ja" } },
    { params: { locale: "zh-hans" } },
    { params: { locale: "zh-hant" } },
    { params: { locale: "es" } },
    { params: { locale: "de" } },
    { params: { locale: "fr" } },
    { params: { locale: "ru" } },
    { params: { locale: "pt-br" } },
    { params: { locale: "ar" } },
    { params: { locale: "ko" } }
  ];
}

const { locale: pathLocale } = Astro.params;
const locale = routeToLocale[pathLocale ?? ""] ?? "en";
const t = i18n[locale];
const meta = seo[locale];
const htmlLang = localeToHtmlLang[locale];
const ogLocale = localeToOgLocale[locale];
const initialDemo = demos.find((d) => d.locale === locale) ?? demos[0];
const sampleText = initialDemo.text;
const currentPath = pathLocale ? `/${pathLocale}/` : "/";
const ogAlternates = localeNames
  .filter((l) => l.locale !== locale)
  .map((l) => localeToOgLocale[l.locale]);
const currentLocaleInfo = localeNames.find((l) => l.locale === locale) ?? localeNames[0];
const analyticsDomain = import.meta.env.PUBLIC_ANALYTICS_DOMAIN;
const analyticsSrc = import.meta.env.PUBLIC_ANALYTICS_SRC;
const repoUrl = "https://github.com/becoolme/privacyfilter.app";
const repoIssuesUrl = `${repoUrl}/issues`;
const repoLicenseUrl = `${repoUrl}/blob/main/LICENSE`;
const repoContribUrl = `${repoUrl}/blob/main/CONTRIBUTING.md`;
const blogPath = pathLocale ? `/${pathLocale}/blog/` : "/blog/";
---

<!doctype html>
<html lang={htmlLang} dir={localeIsRtl[locale] ? "rtl" : "ltr"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.pageTitle}</title>
    <meta name="description" content={meta.metaDescription} />
    <meta
      name="keywords"
      content="privacy filter, PII detection, redact text online, openai privacy filter, browser PII detector, transformers.js, WebGPU NER, anonymize text, data redaction, secrets scanner"
    />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#1769e0" />
    <meta name="color-scheme" content="light" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%231769e0'/%3E%3Cpath d='M50 22 28 32v18c0 14 9 22 22 28 13-6 22-14 22-28V32L50 22zm0 14 14 6v8c0 9-6 14-14 18-8-4-14-9-14-18v-8l14-6z' fill='%23fff'/%3E%3C/svg%3E"
    />

    {localeNames.map((l) => (
      <link
        rel="alternate"
        hreflang={localeToHtmlLang[l.locale]}
        href={l.path}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href="/" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={meta.ogTitle} />
    <meta property="og:description" content={meta.ogDescription} />
    <meta property="og:site_name" content="Privacy Filter" />
    <meta property="og:locale" content={ogLocale} />
    {ogAlternates.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.ogTitle} />
    <meta name="twitter:description" content={meta.ogDescription} />

    <link rel="preconnect" href="https://huggingface.co" crossorigin />
    <link rel="dns-prefetch" href="https://huggingface.co" />
    <link rel="preconnect" href="https://cdn-lfs.huggingface.co" crossorigin />
    <link rel="dns-prefetch" href="https://cdn-lfs.huggingface.co" />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        name: "Privacy Filter",
        description: meta.metaDescription,
        applicationCategory: "SecurityApplication",
        operatingSystem: "Any (Web)",
        browserRequirements:
          "Chrome or Edge with WebGPU recommended; falls back to WebAssembly on other modern browsers.",
        isAccessibleForFree: true,
        offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
        inLanguage: htmlLang,
        featureList: [
          t.trust1Title + " — " + t.trust1Body,
          t.trust2Title + " — " + t.trust2Body,
          t.trust3Title + " — " + t.trust3Body,
          t.trust4Title + " — " + t.trust4Body
        ]
      })}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        inLanguage: htmlLang,
        mainEntity: [
          {
            "@type": "Question",
            name: t.faq1Q,
            acceptedAnswer: { "@type": "Answer", text: t.faq1A }
          },
          {
            "@type": "Question",
            name: t.faq2Q,
            acceptedAnswer: { "@type": "Answer", text: t.faq2A }
          },
          {
            "@type": "Question",
            name: t.faq3Q,
            acceptedAnswer: { "@type": "Answer", text: t.faq3A }
          },
          {
            "@type": "Question",
            name: t.faq4Q,
            acceptedAnswer: { "@type": "Answer", text: t.faq4A }
          },
          {
            "@type": "Question",
            name: t.faq5Q,
            acceptedAnswer: { "@type": "Answer", text: t.faq5A }
          },
          {
            "@type": "Question",
            name: t.faq6Q,
            acceptedAnswer: { "@type": "Answer", text: t.faq6A }
          }
        ]
      })}
    />

    {analyticsDomain && analyticsSrc && (
      <script defer data-domain={analyticsDomain} src={analyticsSrc}></script>
    )}
  </head>
  <body class="bg-bg text-text">
    <main class="mx-auto w-full max-w-[1180px] px-4 py-8 lg:py-9">
      <header
        role="banner"
        class="flex flex-wrap items-center justify-between gap-x-6 gap-y-3 pt-1 pb-5"
      >
        <a
          class="inline-flex items-center gap-2.5 text-text no-underline"
          href={currentPath}
          aria-label={t.homeLinkLabel}
        >
          <span
            aria-hidden="true"
            class="inline-grid place-items-center w-[30px] h-[30px] bg-accent text-white text-xs font-extrabold tracking-wider"
            >PF</span
          >
          <strong class="font-extrabold tracking-tight text-base">Privacy Filter</strong>
        </a>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
          <nav
            aria-label="Primary"
            class="hidden sm:flex flex-wrap gap-x-5 gap-y-1 text-sm"
          >
            <a class="text-muted no-underline hover:text-accent transition-colors" href="#how-it-works">{t.navHow}</a>
            <a class="text-muted no-underline hover:text-accent transition-colors" href="#entity-types">{t.navEntities}</a>
            <a class="text-muted no-underline hover:text-accent transition-colors" href="#use-cases">{t.navUseCases}</a>
            <a class="text-muted no-underline hover:text-accent transition-colors" href="#faq">{t.navFaq}</a>
            <a class="text-muted no-underline hover:text-accent transition-colors" href={blogPath}>{t.navBlog}</a>
            <a class="text-muted no-underline hover:text-accent transition-colors" href="https://huggingface.co/openai/privacy-filter" target="_blank" rel="noopener">{t.navModel}</a>
            <a
              class="inline-flex items-center gap-1.5 text-muted no-underline hover:text-accent transition-colors"
              href={repoUrl}
              target="_blank"
              rel="noopener"
              aria-label={t.navGithub}
            >
              <svg aria-hidden="true" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
                <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
              </svg>
              <span>{t.navGithub}</span>
            </a>
          </nav>
          <details class="relative" aria-label={t.languageMenu}>
            <summary
              class="flex items-center gap-1.5 px-3 py-1.5 border border-line bg-white text-sm font-medium cursor-pointer list-none select-none [&::-webkit-details-marker]:hidden hover:border-accent transition-colors"
            >
              <span lang={localeToHtmlLang[locale]}>{currentLocaleInfo.label}</span>
              <span aria-hidden="true" class="text-muted text-[10px]">▾</span>
            </summary>
            <div
              class="absolute right-0 top-full mt-1 z-20 min-w-[160px] py-1 border border-line bg-white shadow-[0_12px_28px_rgba(20,32,51,0.14)]"
              role="menu"
            >
              {localeNames.map((l) =>
                l.locale === locale ? (
                  <span
                    class="block px-3 py-1.5 text-sm bg-bg text-text font-semibold"
                    aria-current="page"
                    lang={localeToHtmlLang[l.locale]}
                  >
                    {l.label}
                  </span>
                ) : (
                  <a
                    class="block px-3 py-1.5 text-sm text-text no-underline hover:bg-bg transition-colors"
                    href={l.path}
                    hreflang={localeToHtmlLang[l.locale]}
                    lang={localeToHtmlLang[l.locale]}
                    role="menuitem"
                  >
                    {l.label}
                  </a>
                )
              )}
            </div>
          </details>
        </div>
      </header>

      <section
        class="grid grid-cols-1 md:grid-cols-[1fr_minmax(280px,380px)] gap-6 items-end mb-6"
      >
        <div>
          <h1
            class="max-w-[760px] mb-3 text-[clamp(34px,5vw,58px)] leading-[1.04] tracking-tight font-bold"
          >
            {t.title}
          </h1>
          <p class="max-w-[760px] m-0 text-muted text-[17px] leading-[1.65]">
            {t.summary}
          </p>
        </div>
        <div
          aria-live="polite"
          class="grid grid-cols-[14px_1fr] gap-3 p-[18px] border border-line bg-panel"
        >
          <span class="status-dot" id="statusDot"></span>
          <div>
            <p id="statusTitle" class="m-0 mb-1 font-bold">{t.statusIdleTitle}</p>
            <small id="statusDetail" class="text-muted leading-[1.5]">{t.statusIdleDetail}</small>
          </div>
        </div>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
        <div
          class="border border-line bg-panel overflow-hidden"
        >
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-[18px] py-4 min-h-[84px] border-b border-line"
          >
            <h2 class="m-0 text-lg font-semibold">{t.inputTitle}</h2>
            <button
              id="runButton"
              type="button"
              class="min-h-[38px] px-3.5 border border-accent bg-accent text-white font-bold cursor-pointer hover:bg-accent-dark disabled:opacity-55 disabled:cursor-not-allowed transition-colors"
              >{t.runButton}</button
            >
          </div>
          <textarea
            id="inputText"
            spellcheck="false"
            class="w-full min-h-[360px] m-0 border-0 p-[18px] resize-y bg-[#fbfcfe] text-text text-[15px] leading-[1.7] whitespace-pre-wrap focus:outline focus:outline-2 focus:[outline-color:rgba(23,105,224,0.25)] focus:-outline-offset-2"
            >{sampleText}</textarea
          >
          <div
            class="grid grid-cols-2 sm:grid-cols-4 gap-2.5 border-t border-line p-3 bg-white"
            id="demoStrip"
            aria-label="Demo texts"
          ></div>
        </div>

        <div
          class="border border-line bg-panel overflow-hidden"
        >
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-[18px] py-4 min-h-[84px] border-b border-line"
          >
            <div class="flex items-center gap-2">
              <h2 class="m-0 text-lg font-semibold">{t.outputTitle}</h2>
              <span
                id="spanCount"
                class="hidden items-center justify-center min-w-[1.5rem] h-6 px-2 bg-accent text-white text-xs font-bold leading-none"
                aria-live="polite"
                aria-label={t.spansBadgeLabel}
              >0</span>
            </div>
            <button
              id="copyButton"
              type="button"
              disabled
              class="min-h-[38px] px-3.5 border border-line bg-white text-text font-bold cursor-pointer hover:border-accent hover:text-accent disabled:opacity-55 disabled:cursor-not-allowed transition-colors"
              >{t.copyButton}</button
            >
          </div>
          <div class="grid bg-[#fbfcfe]">
            <section>
              <h3 class="m-0 px-[18px] pt-3 text-[13px] font-bold text-muted">{t.annotatedTitle}</h3>
              <div
                id="annotatedText"
                class="w-full min-h-[120px] m-0 border-0 px-[18px] pt-2.5 pb-3.5 bg-[#fbfcfe] text-text text-[15px] leading-[1.65] whitespace-pre-wrap [overflow-wrap:anywhere]"
              >
                {t.annotatedIdle}
              </div>
            </section>
            <section class="border-t border-line">
              <h3 class="m-0 px-[18px] pt-3 text-[13px] font-bold text-muted">{t.redactedTitle}</h3>
              <pre
                id="redactedText"
                class="w-full min-h-[160px] m-0 border-0 px-[18px] pt-3.5 pb-[18px] resize-y bg-[#fbfcfe] text-text text-[15px] leading-[1.65] whitespace-pre-wrap"
                >{t.redactedIdle}</pre>
            </section>
          </div>
        </div>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5 items-stretch">
        <div
          class="border border-line bg-panel overflow-hidden flex flex-col"
        >
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-[18px] py-4 min-h-[84px] border-b border-line"
          >
            <div>
              <h2 class="m-0 text-lg font-semibold">{t.imageInputTitle ?? "Image input"}</h2>
              <p class="mt-1 mb-0 text-sm text-muted">{t.imageInputHint ?? "Run local OCR, then map detected privacy labels back onto the image."}</p>
            </div>
            <label
              class="inline-flex items-center justify-center min-h-[38px] px-3.5 border border-line bg-white text-text font-bold cursor-pointer hover:border-accent hover:text-accent transition-colors"
            >
              {t.imageUploadButton ?? "Upload image"}
              <input id="imageUpload" class="sr-only" type="file" accept="image/*" />
            </label>
          </div>
          <div class="flex-1 flex flex-col p-[18px] bg-[#fbfcfe]">
            <div
              id="imageInputPreviewWrap"
              class="image-frame relative flex-1 mb-3 overflow-hidden border border-line min-h-[260px]"
            >
              <img
                id="imageInputPreview"
                class="block w-full h-auto"
                alt={t.imagePreviewAlt ?? "OCR preview"}
              />
            </div>
            <div
              class="grid grid-cols-2 sm:grid-cols-4 gap-2.5 border-t border-line pt-3"
              id="imageDemoStrip"
              aria-label="Demo images"
            ></div>
          </div>
        </div>

        <div
          class="border border-line bg-panel overflow-hidden flex flex-col"
        >
          <div
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 px-[18px] py-4 min-h-[84px] border-b border-line"
          >
            <div class="flex items-center gap-2">
              <h2 class="m-0 text-lg font-semibold">{t.imageOutputTitle ?? "Image OCR result"}</h2>
              <span
                id="imageSpanCount"
                class="hidden items-center justify-center min-w-[1.5rem] h-6 px-2 bg-accent text-white text-xs font-bold leading-none"
                aria-live="polite"
              >0</span>
            </div>
            <div class="flex flex-wrap sm:flex-nowrap items-center gap-2">
              <label class="inline-flex items-center gap-2 text-sm text-muted">
                <input id="imageDebugToggle" type="checkbox" class="accent-accent" />
                {t.imageDebugLabel ?? "Debug"}
              </label>
              <div class="grid grid-cols-3 gap-1.5 w-full sm:w-auto">
                <button
                  id="addMaskButton"
                  type="button"
                  class="inline-flex min-h-[34px] items-center justify-center px-2.5 border border-line bg-white text-xs leading-none text-text font-bold cursor-pointer hover:border-accent hover:text-accent transition-colors whitespace-nowrap"
                  >{t.imageAddMaskButton ?? "Add mask"}</button
                >
                <button
                  id="downloadImageButton"
                  type="button"
                  class="inline-flex min-h-[34px] items-center justify-center px-2.5 border border-line bg-white text-xs leading-none text-text font-bold cursor-pointer hover:border-accent hover:text-accent transition-colors whitespace-nowrap"
                  >{t.imageDownloadButton ?? "Download"}</button
                >
                <button
                  id="runImageButton"
                  type="button"
                  class="inline-flex min-h-[34px] items-center justify-center px-2.5 border border-accent bg-accent text-xs leading-none text-white font-bold cursor-pointer hover:bg-accent-dark disabled:opacity-55 disabled:cursor-not-allowed transition-colors whitespace-nowrap"
                  >{t.imageRunButton ?? "Scan image"}</button
                >
              </div>
            </div>
          </div>
          <div class="flex-1 flex flex-col gap-3 p-[18px] bg-[#fbfcfe]">
            <p id="imageStatus" class="m-0 text-sm text-muted" aria-live="polite">
              {t.imageStatusIdle ?? "Choose a demo image or upload your own image."}
            </p>
            <div
              id="imagePreviewWrap"
              class="image-frame relative flex-1 overflow-hidden border border-line min-h-[260px]"
            >
              <canvas
                id="imageCanvas"
                class="block w-full h-auto cursor-crosshair touch-none"
                aria-label={t.imagePreviewAlt ?? "OCR preview"}
              ></canvas>
            </div>
            <details id="imageDebugPanel" class="hidden border border-line bg-white">
              <summary class="cursor-pointer px-3 py-2 text-sm font-bold text-text">
                {t.imageDebugTitle ?? "OCR debug"}
              </summary>
              <pre
                id="imageDebugOutput"
                class="m-0 max-h-[360px] overflow-auto border-t border-line p-3 text-xs leading-relaxed whitespace-pre-wrap"
              ></pre>
            </details>
          </div>
        </div>
      </section>

      <section
        aria-label="Privacy guarantees"
        class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-5 mt-5 mb-6 p-[18px] border border-line bg-panel"
      >
        <div class="grid gap-1 md:px-1 md:[&:not(:first-child)]:border-l md:[&:not(:first-child)]:border-line md:[&:not(:first-child)]:pl-[18px]">
          <strong class="text-sm text-text">{t.trust1Title}</strong>
          <span class="text-[13px] text-muted leading-[1.55]">{t.trust1Body}</span>
        </div>
        <div class="grid gap-1 md:px-1 md:[&:not(:first-child)]:border-l md:[&:not(:first-child)]:border-line md:[&:not(:first-child)]:pl-[18px]">
          <strong class="text-sm text-text">{t.trust2Title}</strong>
          <span class="text-[13px] text-muted leading-[1.55]">{t.trust2Body}</span>
        </div>
        <div class="grid gap-1 md:px-1 md:[&:not(:first-child)]:border-l md:[&:not(:first-child)]:border-line md:[&:not(:first-child)]:pl-[18px]">
          <strong class="text-sm text-text">{t.trust3Title}</strong>
          <span class="text-[13px] text-muted leading-[1.55]">{t.trust3Body}</span>
        </div>
        <div class="grid gap-1 md:px-1 md:[&:not(:first-child)]:border-l md:[&:not(:first-child)]:border-line md:[&:not(:first-child)]:pl-[18px]">
          <strong class="text-sm text-text">{t.trust4Title}</strong>
          <span class="text-[13px] text-muted leading-[1.55]">{t.trust4Body}</span>
        </div>
      </section>

      <section
        id="how-it-works"
        aria-labelledby="howTitle"
        class="border border-line bg-panel overflow-hidden mt-5"
      >
        <div class="px-[18px] py-4 border-b border-line">
          <h2 id="howTitle" class="m-0 text-lg font-semibold">{t.howTitle}</h2>
        </div>
        <ol class="grid grid-cols-1 md:grid-cols-3 m-0 p-0 list-none">
          <li class="px-5 py-[18px] border-b md:border-b-0 md:border-r border-line last:border-b-0 md:last:border-r-0">
            <span aria-hidden="true" class="inline-grid place-items-center w-[26px] h-[26px] mb-2.5 bg-[rgba(23,105,224,0.12)] text-accent text-[13px] font-extrabold">1</span>
            <strong class="block mb-1.5 text-[15px]">{t.how1Title}</strong>
            <p class="m-0 text-muted text-sm leading-[1.6]">{t.how1Body}</p>
          </li>
          <li class="px-5 py-[18px] border-b md:border-b-0 md:border-r border-line last:border-b-0 md:last:border-r-0">
            <span aria-hidden="true" class="inline-grid place-items-center w-[26px] h-[26px] mb-2.5 bg-[rgba(23,105,224,0.12)] text-accent text-[13px] font-extrabold">2</span>
            <strong class="block mb-1.5 text-[15px]">{t.how2Title}</strong>
            <p class="m-0 text-muted text-sm leading-[1.6]">{t.how2Body}</p>
          </li>
          <li class="px-5 py-[18px] border-b md:border-b-0 md:border-r border-line last:border-b-0 md:last:border-r-0">
            <span aria-hidden="true" class="inline-grid place-items-center w-[26px] h-[26px] mb-2.5 bg-[rgba(23,105,224,0.12)] text-accent text-[13px] font-extrabold">3</span>
            <strong class="block mb-1.5 text-[15px]">{t.how3Title}</strong>
            <p class="m-0 text-muted text-sm leading-[1.6]">{t.how3Body}</p>
          </li>
        </ol>
      </section>

      <section
        id="entity-types"
        aria-labelledby="entitiesTitle"
        class="border border-line bg-panel overflow-hidden mt-5"
      >
        <div class="px-[18px] py-4 border-b border-line">
          <h2 id="entitiesTitle" class="m-0 text-lg font-semibold">{t.entitiesTitle}</h2>
          <p class="mt-1 mb-0 text-sm text-muted">{t.entitiesIntro}</p>
        </div>
