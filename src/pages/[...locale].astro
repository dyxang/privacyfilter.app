    <script>
      import { pipeline, env } from "@huggingface/transformers";
      import { createWorker } from "tesseract.js";
      import { i18n, demos } from "../lib/i18n";
      import { regexScan, mergeSpans, PATTERN_DESCRIPTIONS } from "../lib/regexPatterns";

      env.allowLocalModels = false;
      env.remoteHost =
        window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1"
          ? "https://huggingface.co/"
          : `${window.location.origin}/hf/`;
      env.useBrowserCache = true;
      env.useWasmCache = true;
      env.cacheKey = "privacy-filter-model-v1";

      const isMobileLikeDevice = () => {
        const coarsePointer = window.matchMedia?.("(pointer: coarse)")?.matches ?? false;
        const mobileUserAgent = /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent);
        const deviceMemory = Number(navigator.deviceMemory ?? 8);
        return coarsePointer || mobileUserAgent || deviceMemory <= 4;
      };

      const mobileLikeDevice = isMobileLikeDevice();
      if (env.backends?.onnx?.wasm) {
        env.backends.onnx.wasm.numThreads = mobileLikeDevice ? 1 : Math.min(navigator.hardwareConcurrency || 4, 4);
      }

      const inputText = document.querySelector("#inputText");
      const runButton = document.querySelector("#runButton");
      const copyButton = document.querySelector("#copyButton");
      const demoStrip = document.querySelector("#demoStrip");
      const annotatedText = document.querySelector("#annotatedText");
      const redactedText = document.querySelector("#redactedText");
      const spanCount = document.querySelector("#spanCount");
      const imageUpload = document.querySelector("#imageUpload");
      const imageDemoStrip = document.querySelector("#imageDemoStrip");
      const runImageButton = document.querySelector("#runImageButton");
      const imageDebugToggle = document.querySelector("#imageDebugToggle");
      const imageDebugPanel = document.querySelector("#imageDebugPanel");
      const imageDebugOutput = document.querySelector("#imageDebugOutput");
      const imageStatus = document.querySelector("#imageStatus");
      const imageInputPreview = document.querySelector("#imageInputPreview");
      const imageCanvas = document.querySelector("#imageCanvas");
      const addMaskButton = document.querySelector("#addMaskButton");
      const downloadImageButton = document.querySelector("#downloadImageButton");
      const imageSpanCount = document.querySelector("#imageSpanCount");
      const statusDot = document.querySelector("#statusDot");
      const statusTitle = document.querySelector("#statusTitle");
      const statusDetail = document.querySelector("#statusDetail");

      let classifier = null;
      let lastRedacted = "";
      let lastSource = "";
      let lastSpans = [];
      const initialLang = document.documentElement.lang || "en";
      let currentLocale = i18n[initialLang] ? initialLang : "en";
      let modelPromise = null;
      let modelLoading = false;
      let detectTimer = null;
      let pendingDetection = false;
      let ocrWorker = null;
      let ocrPromise = null;
      let currentImageInput = null;
      let currentImageObjectUrl = null;
      let currentImageNaturalSize = { width: 1, height: 1 };
      let currentImageElement = null;
      let imageMasks = [];
      let selectedMaskId = null;
      let maskDragState = null;
      let lastImageDebug = null;

      const t = (key, ...args) => {
        const value = i18n[currentLocale][key] ?? i18n.en[key] ?? key;
        return typeof value === "function" ? value(...args) : value;
      };

      const setStatus = (state, title, detail = "") => {
        statusDot.dataset.state = state;
        statusTitle.textContent = title;
        statusDetail.textContent = detail;
      };

      const getDevice = () => {
        if (mobileLikeDevice) return "wasm";
        return "gpu" in navigator ? "webgpu" : "wasm";
      };

      const labelFor = (label) => i18n[currentLocale].labels[label] || i18n.en.labels[label] || label;

      const labelColors = {
        account_number: "account",
        private_address: "address",
        private_email: "email",
        private_person: "person",
        private_phone: "phone",
        private_url: "url",
        private_date: "date",
        secret: "secret"
      };

      const rawLabelFor = (label) => label.toUpperCase();

      const imageDemos = [
        {
          id: "support-ticket",
          title: "Support ticket",
          lines: [
            "Customer: Alice Smith",
            "Email: alice.smith@example.com",
            "Phone: +1 (415) 555-0134",
            "Token: sk-live-1234567890abcdef"
          ]
        },
        {
          id: "invoice-note",
          title: "Invoice note",
          lines: [
            "Vendor: Jordan Lee",
            "Account: AC-44092811",
            "Due: May 9, 2026",
            "URL: https://billing.example.com/invoice/8842"
          ]
        }
      ];

      const updateSpanCount = (count) => {
        spanCount.textContent = String(count);
        spanCount.classList.toggle("hidden", count === 0);
        spanCount.classList.toggle("inline-flex", count > 0);
      };

      const updateImageSpanCount = (count) => {
        imageSpanCount.textContent = String(count);
        imageSpanCount.classList.toggle("hidden", count === 0);
        imageSpanCount.classList.toggle("inline-flex", count > 0);
      };

      const renderImageDebug = () => {
        const enabled = Boolean(imageDebugToggle.checked);
        imageDebugPanel.classList.toggle("hidden", !enabled);

        if (!enabled) return;
        imageDebugOutput.textContent = lastImageDebug
          ? JSON.stringify(lastImageDebug, null, 2)
          : "No image scan debug data yet.";
      };

      const refreshDynamicText = () => {
        runButton.textContent = modelLoading ? t("modelLoadingButton") : t("runButton");
        if (lastSource) {
          renderResult();
        } else {
          updateSpanCount(0);
        }
      };

      const renderDemos = () => {
        demoStrip.replaceChildren(
          ...demos.map((demo) => {
            const button = document.createElement("button");
            button.type = "button";
            button.className = "demo-button";
            button.dataset.demoId = demo.id;
            const titleEl = document.createElement("strong");
            titleEl.textContent = demo.title;
            const descEl = document.createElement("span");
            descEl.textContent = demo.description;
            button.replaceChildren(titleEl, descEl);
            button.addEventListener("click", async () => {
              inputText.value = demo.text;
              lastSource = "";
              lastSpans = [];
              lastRedacted = "";
              copyButton.disabled = true;
              annotatedText.textContent = t("annotatedIdle");
              redactedText.textContent = t("redactedIdle");
              setActiveDemo(demo.id);
              refreshDynamicText();
              if (classifier) await runDetection();
            });
            return button;
          })
        );
        const initialDemoId = demos.find((d) => d.locale === currentLocale)?.id ?? demos[0].id;
        setActiveDemo(initialDemoId);
      };

      const setActiveDemo = (id) => {
        demoStrip.querySelectorAll(".demo-button").forEach((button) => {
          button.toggleAttribute("aria-current", button.dataset.demoId === id);
        });
      };

      const createDemoImage = (demo) => {
        const canvas = document.createElement("canvas");
        const scale = window.devicePixelRatio || 1;
        const width = 980;
        const height = 360;
        canvas.width = width * scale;
        canvas.height = height * scale;
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;

        const ctx = canvas.getContext("2d");
        ctx.scale(scale, scale);
        ctx.fillStyle = "#ffffff";
        ctx.fillRect(0, 0, width, height);
        ctx.fillStyle = "#f6f8fb";
        ctx.fillRect(0, 0, width, 72);
        ctx.fillStyle = "#142033";
        ctx.font = "700 34px Arial, sans-serif";
        ctx.fillText(demo.title, 36, 48);
        ctx.font = "28px Arial, sans-serif";
        demo.lines.forEach((line, index) => {
          ctx.fillText(line, 36, 118 + index * 58);
        });

        return canvas.toDataURL("image/png");
      };

      const drawImageCanvas = () => {
        if (!currentImageElement) return;

        const { width, height } = currentImageNaturalSize;
        imageCanvas.width = width;
        imageCanvas.height = height;
        const ctx = imageCanvas.getContext("2d");
        ctx.clearRect(0, 0, width, height);
        ctx.drawImage(currentImageElement, 0, 0, width, height);
        ctx.fillStyle = "#1769e0";

        for (const mask of imageMasks) {
          ctx.fillRect(mask.x, mask.y, mask.width, mask.height);
          if (mask.id === selectedMaskId) {
            ctx.save();
            ctx.strokeStyle = "#ffffff";
            ctx.lineWidth = Math.max(2, width * 0.002);
            ctx.setLineDash([8, 5]);
            ctx.strokeRect(mask.x, mask.y, mask.width, mask.height);
            const handleSize = getResizeHandleVisualSize();
            ctx.fillStyle = "#1769e0";
            ctx.fillRect(mask.x + mask.width - handleSize / 2, mask.y + mask.height - handleSize / 2, handleSize, handleSize);
            ctx.setLineDash([]);
            ctx.strokeStyle = "#ffffff";
            ctx.strokeRect(mask.x + mask.width - handleSize / 2, mask.y + mask.height - handleSize / 2, handleSize, handleSize);
            ctx.restore();
            ctx.fillStyle = "#1769e0";
          }
        }

        updateImageSpanCount(imageMasks.length);
      };

      const clampMask = (mask) => {
        const minSize = 8;
        mask.width = Math.max(minSize, Math.min(mask.width, currentImageNaturalSize.width - mask.x));
        mask.height = Math.max(minSize, Math.min(mask.height, currentImageNaturalSize.height - mask.y));
        mask.x = Math.max(0, Math.min(mask.x, currentImageNaturalSize.width - mask.width));
        mask.y = Math.max(0, Math.min(mask.y, currentImageNaturalSize.height - mask.height));
        return mask;
      };

      const createMask = (box, source = "manual") =>
        clampMask({
          id: crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random()}`,
          x: box.x,
          y: box.y,
          width: box.width,
          height: box.height,
          source
        });

      const canvasPointFromEvent = (event) => {
        const rect = imageCanvas.getBoundingClientRect();
        return {
          x: ((event.clientX - rect.left) / rect.width) * currentImageNaturalSize.width,
          y: ((event.clientY - rect.top) / rect.height) * currentImageNaturalSize.height
        };
      };

      const getMaskAtPoint = (point) =>
        [...imageMasks].reverse().find(
          (mask) =>
            point.x >= mask.x &&
            point.x <= mask.x + mask.width &&
            point.y >= mask.y &&
            point.y <= mask.y + mask.height
        );

      const getResizeHandleSize = () =>
        Math.max(22, currentImageNaturalSize.width * 0.02);

      const getResizeHandleVisualSize = () =>
        Math.max(8, currentImageNaturalSize.width * 0.006);

      const isResizeHandle = (mask, point) => {
        const handleSize = getResizeHandleSize();
        const handleCenterX = mask.x + mask.width;
        const handleCenterY = mask.y + mask.height;
        return (
          point.x >= handleCenterX - handleSize / 2 &&
          point.x <= handleCenterX + handleSize / 2 &&
          point.y >= handleCenterY - handleSize / 2 &&
          point.y <= handleCenterY + handleSize / 2
        );
      };

      const getResizeHandleAtPoint = (point) =>
        [...imageMasks].reverse().find((mask) => isResizeHandle(mask, point));

      const isInsideResizeArea = (mask, point) => {
        const handleSize = Math.max(18, currentImageNaturalSize.width * 0.018);
        return point.x >= mask.x + mask.width - handleSize && point.y >= mask.y + mask.height - handleSize;
      };

      const setImageSource = async (src, input, demoId = null) => {
        if (currentImageObjectUrl) {
          URL.revokeObjectURL(currentImageObjectUrl);
          currentImageObjectUrl = null;
        }

        currentImageInput = input;
        lastImageDebug = null;
        imageMasks = [];
        selectedMaskId = null;
        updateImageSpanCount(0);
        renderImageDebug();
        imageStatus.textContent = t("imageStatusReady") ?? "Image ready. OCR will run locally in your browser.";

        await new Promise((resolve, reject) => {
          const image = new Image();
          image.onload = () => {
            currentImageElement = image;
            currentImageNaturalSize = {
              width: image.naturalWidth || 1,
              height: image.naturalHeight || 1
            };
            drawImageCanvas();
            resolve();
          };
          image.onerror = reject;
          image.src = src;
          imageInputPreview.src = src;
        });

        imageDemoStrip.querySelectorAll(".image-demo-button").forEach((button) => {
          button.toggleAttribute("aria-current", button.dataset.demoId === demoId);
        });
      };

      const renderImageDemos = () => {
        imageDemoStrip.replaceChildren(
          ...imageDemos.map((demo) => {
            const button = document.createElement("button");
            button.type = "button";
            button.className = "image-demo-button demo-button";
            button.dataset.demoId = demo.id;

            const thumb = document.createElement("img");
            thumb.className = "image-demo-thumb";
            thumb.alt = "";
            thumb.loading = "lazy";
            thumb.decoding = "async";
            thumb.src = createDemoImage(demo);

            const caption = document.createElement("div");
            caption.className = "image-demo-caption";
            const captionTitle = document.createElement("strong");
            captionTitle.textContent = demo.title;
            const captionDesc = document.createElement("span");
            captionDesc.textContent = demo.lines[0];
            caption.append(captionTitle, captionDesc);

            button.append(thumb, caption);
            button.addEventListener("click", async () => {
              const src = createDemoImage(demo);
              await setImageSource(src, src, demo.id);
              runImageDetection();
            });
            return button;
          })
        );
      };

      const loadModel = async () => {
        if (classifier) return classifier;
        if (modelPromise) return modelPromise;

        const device = getDevice();
        modelLoading = true;
        setStatus("loading", t("loadingModel"), t("loadingModelDetail", device));
        runButton.textContent = t("modelLoadingButton");

        modelPromise = pipeline("token-classification", "openai/privacy-filter", {
            device,
            dtype: "q4",
            progress_callback: (progress) => {
              if (!progress?.file) return;
              const percent = Number.isFinite(progress.progress) ? ` ${Math.round(progress.progress)}%` : "";
              setStatus("loading", t("downloadingModel"), `${progress.file}${percent}`);
            }
          })
          .then((loadedClassifier) => {
            classifier = loadedClassifier;
            setStatus("ready", t("readyTitle"), t("readyDetail", device));
            scheduleDetection(0);
            return classifier;
          })
          .catch((error) => {
            console.error(error);
            const message = error instanceof Error ? error.message : String(error);
            setStatus("error", t("loadError"), message);
            throw error;
          })
          .finally(() => {
            modelLoading = false;
            modelPromise = null;
            runButton.textContent = t("runButton");
          });

        return modelPromise;
      };

      const loadOcrWorker = async () => {
        if (ocrWorker) return ocrWorker;
        if (ocrPromise) return ocrPromise;

        imageStatus.textContent = t("imageOcrLoading") ?? "Loading local OCR model...";
        ocrPromise = createWorker("eng", 1, {
          logger: (message) => {
            if (!message?.status) return;
            const percent = Number.isFinite(message.progress)
              ? ` ${Math.round(message.progress * 100)}%`
              : "";
            imageStatus.textContent = `${t("imageOcrLoading") ?? "Loading local OCR model..."} ${message.status}${percent}`;
          }
        })
          .then(async (worker) => {
            ocrWorker = worker;
            await ocrWorker.setParameters({
              preserve_interword_spaces: "1"
            });
            return ocrWorker;
          })
          .finally(() => {
            ocrPromise = null;
          });

        return ocrPromise;
      };

      const collectOcrWords = (blocks) => {
        const words = [];
        for (const block of blocks ?? []) {
          for (const paragraph of block.paragraphs ?? []) {
            for (const line of paragraph.lines ?? []) {
              for (const word of line.words ?? []) {
                const text = String(word.text ?? "").trim();
                if (!text || !word.bbox) continue;
                words.push({
                  text,
                  confidence: Number(word.confidence ?? 0),
                  bbox: word.bbox
                });
              }
            }
          }
        }
        return words;
      };

      const buildTextFromOcrWords = (ocrWords) => {
        let text = "";
        const words = [];

        for (const word of ocrWords) {
          const separator = text ? " " : "";
          const start = text.length + separator.length;
          text += separator + word.text;
          words.push({
            ...word,
            start,
            end: start + word.text.length
          });
        }

        return { text, words };
      };

      const median = (values) => {
        if (!values.length) return 0;
        const sorted = [...values].sort((a, b) => a - b);
        const middle = Math.floor(sorted.length / 2);
        return sorted.length % 2 ? sorted[middle] : (sorted[middle - 1] + sorted[middle]) / 2;
      };

      const getWordCenterY = (word) => (word.bbox.y0 + word.bbox.y1) / 2;

      const getPrimaryLineWords = (words) => {
        if (words.length <= 2) return words;

        const heights = words.map((word) => word.bbox.y1 - word.bbox.y0).filter((height) => height > 0);
        const medianHeight = median(heights) || 1;
        const buckets = [];

        for (const word of words) {
          const centerY = getWordCenterY(word);
          const bucket = buckets.find((item) => Math.abs(item.centerY - centerY) <= medianHeight * 0.9);
          if (bucket) {
            bucket.words.push(word);
            bucket.centerY = median(bucket.words.map(getWordCenterY));
          } else {
            buckets.push({ centerY, words: [word] });
          }
        }

        return buckets.sort((a, b) => b.words.length - a.words.length)[0]?.words ?? words;
      };

      const mergeWordBoxes = (words) =>
        words.reduce(
          (box, word) => ({
            x0: Math.min(box.x0, word.bbox.x0),
            y0: Math.min(box.y0, word.bbox.y0),
            x1: Math.max(box.x1, word.bbox.x1),
            y1: Math.max(box.y1, word.bbox.y1)
          }),
          { x0: Infinity, y0: Infinity, x1: -Infinity, y1: -Infinity }
        );

      const renderImageOverlays = (text, spans, words) => {
        imageMasks = [];
        selectedMaskId = null;
        const imageWidth = currentImageNaturalSize.width || 1;
        const imageHeight = currentImageNaturalSize.height || 1;
        const maxReasonableWordHeight = imageHeight * 0.18;
        const maxReasonableWordWidth = imageWidth * 0.8;

        for (const span of spans) {
          const matchedWords = words.filter((word) => {
            const wordWidth = word.bbox.x1 - word.bbox.x0;
            const wordHeight = word.bbox.y1 - word.bbox.y0;
            return (
              word.end > span.start &&
              word.start < span.end &&
              wordWidth > 2 &&
              wordHeight > 2 &&
              wordWidth < maxReasonableWordWidth &&
              wordHeight < maxReasonableWordHeight
            );
          });
          if (!matchedWords.length) continue;

          const lineWords = getPrimaryLineWords(matchedWords);
          const box = mergeWordBoxes(lineWords);
          const top = Math.max(0, box.y0 - 5);
          const bottom = Math.min(imageHeight, box.y1 + 5);
          imageMasks.push(
            createMask(
              {
                x: box.x0,
                y: top,
                width: box.x1 - box.x0,
                height: Math.max(2, bottom - top)
              },
              span.label
            )
          );
        }
        drawImageCanvas();
      };

      const getImageSpanMatches = (spans, words) => {
        const imageWidth = currentImageNaturalSize.width || 1;
        const imageHeight = currentImageNaturalSize.height || 1;
        const maxReasonableWordHeight = imageHeight * 0.18;
        const maxReasonableWordWidth = imageWidth * 0.8;

        return spans.map((span) => {
          const rawMatchedWords = words.filter((word) => word.end > span.start && word.start < span.end);
          const matchedWords = rawMatchedWords.filter((word) => {
            const wordWidth = word.bbox.x1 - word.bbox.x0;
            const wordHeight = word.bbox.y1 - word.bbox.y0;
            return wordWidth > 2 && wordHeight > 2 && wordWidth < maxReasonableWordWidth && wordHeight < maxReasonableWordHeight;
          });
          const lineWords = getPrimaryLineWords(matchedWords);

          return {
            span: {
              label: span.label,
              score: Number(span.score.toFixed(4)),
              text: span.text,
              start: span.start,
              end: span.end
            },
            rawMatchedWords: rawMatchedWords.map((word) => ({
              text: word.text,
              confidence: Number(word.confidence.toFixed?.(2) ?? word.confidence),
              start: word.start,
              end: word.end,
              bbox: word.bbox
            })),
            renderedWords: lineWords.map((word) => ({
              text: word.text,
              confidence: Number(word.confidence.toFixed?.(2) ?? word.confidence),
              start: word.start,
              end: word.end,
              bbox: word.bbox
            })),
            renderedBox: lineWords.length ? mergeWordBoxes(lineWords) : null
          };
        });
      };

      const runImageDetection = async () => {
        if (!currentImageInput) {
          imageStatus.textContent = t("imageStatusIdle") ?? "Choose a demo image or upload your own image.";
          return;
        }

        runImageButton.disabled = true;
        updateImageSpanCount(0);
        imageMasks = [];
        selectedMaskId = null;
        drawImageCanvas();

        try {
          imageStatus.textContent = t("imageDetecting") ?? "Running OCR and privacy detection...";
          await loadModel();
          const worker = await loadOcrWorker();
          const { data } = await worker.recognize(currentImageInput, {}, { blocks: true, text: true });
          const ocrWords = collectOcrWords(data.blocks);
          const { text, words } = buildTextFromOcrWords(ocrWords);

          if (!text.trim()) {
            imageStatus.textContent = t("imageNoText") ?? "No text was detected in the image.";
            return;
          }

          const raw = await classifier(text, { aggregation_strategy: "simple" });
          let searchFrom = 0;
          const modelSpans = raw
            .map((span) => {
              const normalized = normalizeSpan(span, text, searchFrom);
              if (normalized.end > searchFrom) searchFrom = normalized.end;
              return normalized;
            })
            .filter((span) => span.text);

          const regexSpans = regexScan(text);
          const spans = mergeSpans(modelSpans, regexSpans, text);

          renderImageOverlays(text, spans, words);
          lastImageDebug = {
            image: currentImageNaturalSize,
            ocrText: data.text,
            reconstructedText: text,
            ocrWords: words.map((word) => ({
              text: word.text,
              confidence: Number(word.confidence.toFixed?.(2) ?? word.confidence),
              start: word.start,
              end: word.end,
              bbox: word.bbox,
              size: {
                width: word.bbox.x1 - word.bbox.x0,
                height: word.bbox.y1 - word.bbox.y0
              }
            })),
            privacySpans: spans.map((span) => ({
              label: span.label,
              score: Number(span.score.toFixed(4)),
              text: span.text,
              start: span.start,
              end: span.end
            })),
            spanMatches: getImageSpanMatches(spans, words)
          };
          renderImageDebug();
          imageStatus.textContent = "";
        } catch (error) {
          console.error(error);
          const message = error instanceof Error ? error.message : String(error);
          imageStatus.textContent = `${t("imageError") ?? "Image scan failed."} ${message}`;
        } finally {
          runImageButton.disabled = false;
        }
      };

      const addManualMask = () => {
        if (!currentImageElement) return;
        const width = Math.max(80, currentImageNaturalSize.width * 0.22);
        const height = Math.max(28, currentImageNaturalSize.height * 0.08);
        const mask = createMask(
          {
            x: (currentImageNaturalSize.width - width) / 2,
            y: (currentImageNaturalSize.height - height) / 2,
            width,
            height
          },
          "manual"
        );
        imageMasks.push(mask);
        selectedMaskId = mask.id;
        drawImageCanvas();
      };

      const downloadMaskedImage = () => {
        if (!currentImageElement) return;
        const previousSelection = selectedMaskId;
        selectedMaskId = null;
        drawImageCanvas();
        const link = document.createElement("a");
        link.href = imageCanvas.toDataURL("image/png");
        link.download = "privacy-filter-masked.png";
        link.click();
        selectedMaskId = previousSelection;
        drawImageCanvas();
      };

      const deleteMaskAtPoint = (event) => {
        if (!currentImageElement) return;
        const mask = getMaskAtPoint(canvasPointFromEvent(event));
        if (!mask) return;
        imageMasks = imageMasks.filter((item) => item.id !== mask.id);
        selectedMaskId = null;
        maskDragState = null;
        drawImageCanvas();
      };

      const deleteSelectedMask = () => {
        if (selectedMaskId === null) return;
        imageMasks = imageMasks.filter((item) => item.id !== selectedMaskId);
        selectedMaskId = null;
        maskDragState = null;
        drawImageCanvas();
      };

      const handleMaskDeleteKey = (event) => {
        if (event.key !== "Delete" && event.key !== "Backspace") return;
        const activeElement = document.activeElement;
        const isTyping =
          activeElement instanceof HTMLInputElement ||
          activeElement instanceof HTMLTextAreaElement ||
          activeElement?.isContentEditable;
        if (isTyping || selectedMaskId === null) return;

        event.preventDefault();
        deleteSelectedMask();
      };

      const handleCanvasPointerDown = (event) => {
        if (!currentImageElement) return;
        const point = canvasPointFromEvent(event);
        const resizeMask = getResizeHandleAtPoint(point);
        const mask = resizeMask ?? getMaskAtPoint(point);

        if (!mask) {
          selectedMaskId = null;
          maskDragState = null;
          drawImageCanvas();
          return;
        }

        selectedMaskId = mask.id;
        maskDragState = {
          mode: resizeMask || isInsideResizeArea(mask, point) ? "resize" : "move",
          maskId: mask.id,
          startPoint: point,
          startMask: { ...mask }
        };
        imageCanvas.setPointerCapture(event.pointerId);
        drawImageCanvas();
      };

      const handleCanvasPointerMove = (event) => {
        const point = canvasPointFromEvent(event);
        if (!maskDragState) {
          const resizeMask = getResizeHandleAtPoint(point);
          const mask = resizeMask ?? getMaskAtPoint(point);
          imageCanvas.style.cursor = resizeMask
            ? "nwse-resize"
            : mask
              ? "move"
              : "crosshair";
          return;
        }

        const mask = imageMasks.find((item) => item.id === maskDragState.maskId);
        if (!mask) return;
        imageCanvas.style.cursor = maskDragState.mode === "resize" ? "nwse-resize" : "move";

        const dx = point.x - maskDragState.startPoint.x;
        const dy = point.y - maskDragState.startPoint.y;

        if (maskDragState.mode === "move") {
          mask.x = maskDragState.startMask.x + dx;
          mask.y = maskDragState.startMask.y + dy;
        } else {
          mask.width = maskDragState.startMask.width + dx;
          mask.height = maskDragState.startMask.height + dy;
        }

        clampMask(mask);
        drawImageCanvas();
      };

      const handleCanvasPointerUp = (event) => {
        if (!maskDragState) return;
        maskDragState = null;
        try {
          imageCanvas.releasePointerCapture(event.pointerId);
        } catch {}
      };

      const resetCanvasCursor = () => {
        if (!maskDragState) imageCanvas.style.cursor = "crosshair";
      };

      const normalizeSpan = (span, source, searchFrom) => {
        const label = span.entity_group || span.entity || "unknown";
        const cleanWord = String(span.word || "").replace(/^##/, "").trim();
        let start = Number.isInteger(span.start) ? span.start : -1;
        let end = Number.isInteger(span.end) ? span.end : -1;

        if ((start < 0 || end < 0) && cleanWord) {
          const found = source.indexOf(cleanWord, searchFrom);
          if (found >= 0) {
            start = found;
            end = found + cleanWord.length;
          }
        }

        return {
          label,
          score: typeof span.score === "number" ? span.score : 0,
          text: start >= 0 && end > start ? source.slice(start, end) : cleanWord,
          start,
          end
        };
      };

      const redact = (source, spans) => {
        const usable = spans
          .filter((span) => span.start >= 0 && span.end > span.start)
          .sort((a, b) => a.start - b.start || b.end - a.end);

        let cursor = 0;
        let output = "";

        for (const span of usable) {
          if (span.start < cursor) continue;
          output += source.slice(cursor, span.start);
          output += `[${labelFor(span.label)}]`;
          cursor = span.end;
        }

        return output + source.slice(cursor);
      };

      const getUsableSpans = (spans) =>
        spans
          .filter((span) => span.start >= 0 && span.end > span.start)
          .sort((a, b) => a.start - b.start || b.end - a.end);

      const renderAnnotatedResult = () => {
        annotatedText.replaceChildren();

        if (!lastSource) {
          annotatedText.textContent = t("annotatedIdle");
          return;
        }

        const usable = getUsableSpans(lastSpans);
        if (!usable.length) {
          annotatedText.textContent = lastSource;
          return;
        }

        let cursor = 0;
        for (const span of usable) {
          if (span.start < cursor) continue;

          if (span.start > cursor) {
            annotatedText.append(document.createTextNode(lastSource.slice(cursor, span.start)));
          }

          const chip = document.createElement("span");
          chip.className = `entity-chip entity-chip--${labelColors[span.label] || "default"}`;
          const description = span.source && PATTERN_DESCRIPTIONS[span.source] ? ` · ${PATTERN_DESCRIPTIONS[span.source]}` : "";
          chip.title = `${rawLabelFor(span.label)} · ${labelFor(span.label)}${description} · ${(span.score * 100).toFixed(2)}%`;

          const value = document.createElement("span");
          value.className = "entity-value";
          value.textContent = lastSource.slice(span.start, span.end);

          const label = document.createElement("span");
          label.className = "entity-label";
          label.textContent = rawLabelFor(span.label);

          chip.append(value, label);
          annotatedText.append(chip);
          cursor = span.end;
        }

        if (cursor < lastSource.length) {
          annotatedText.append(document.createTextNode(lastSource.slice(cursor)));
        }
      };

      const renderResult = () => {
        lastRedacted = redact(lastSource, lastSpans);
        renderAnnotatedResult();
        redactedText.textContent = lastRedacted || t("redactedIdle");
        updateSpanCount(lastSpans.length);
        copyButton.disabled = !lastRedacted;
      };

      const runDetection = async () => {
        if (!classifier) {
          runButton.textContent = t("modelLoadingButton");
          try {
            await loadModel();
          } catch {
            runButton.textContent = t("runButton");
            return;
          }
        }
        if (!classifier) return;

        const source = inputText.value.trim();
        if (!source) {
          lastSource = "";
          lastSpans = [];
          lastRedacted = "";
          annotatedText.textContent = t("annotatedIdle");
          redactedText.textContent = t("emptyInput");
          updateSpanCount(0);
          return;
        }

        runButton.disabled = true;
        copyButton.disabled = true;
        setStatus("loading", t("detecting"), t("detectingDetail"));

        try {
          const raw = await classifier(source, { aggregation_strategy: "simple" });
          let searchFrom = 0;
          const modelSpans = raw
            .map((span) => {
              const normalized = normalizeSpan(span, source, searchFrom);
              if (normalized.end > searchFrom) searchFrom = normalized.end;
              return normalized;
            })
            .filter((span) => span.text);

          const regexSpans = regexScan(source);
          const spans = mergeSpans(modelSpans, regexSpans, source);

          lastSource = source;
          lastSpans = spans;
          renderResult();
          setStatus("ready", t("doneTitle"), t("doneDetail", spans.length));
        } catch (error) {
          console.error(error);
          const message = error instanceof Error ? error.message : String(error);
          setStatus("error", t("detectError"), message);
        } finally {
          runButton.disabled = false;
          if (pendingDetection) {
            pendingDetection = false;
            scheduleDetection(120);
          }
        }
      };

      const scheduleDetection = (delay = 450) => {
        window.clearTimeout(detectTimer);
        if (!inputText.value.trim()) return;

        detectTimer = window.setTimeout(() => {
          if (runButton.disabled) {
            pendingDetection = true;
            return;
          }
          runDetection();
        }, delay);
      };

      inputText.addEventListener("input", () => {
        lastSource = "";
        lastSpans = [];
        lastRedacted = "";
        copyButton.disabled = true;
        annotatedText.textContent = t("annotatedIdle");
        redactedText.textContent = t("redactedIdle");
        updateSpanCount(0);
        scheduleDetection();
      });
      runButton.addEventListener("click", runDetection);
      imageDebugToggle.addEventListener("change", renderImageDebug);
      runImageButton.addEventListener("click", runImageDetection);
      addMaskButton.addEventListener("click", addManualMask);
      downloadImageButton.addEventListener("click", downloadMaskedImage);
      imageCanvas.addEventListener("pointerdown", handleCanvasPointerDown);
      imageCanvas.addEventListener("pointermove", handleCanvasPointerMove);
      imageCanvas.addEventListener("pointerup", handleCanvasPointerUp);
      imageCanvas.addEventListener("pointercancel", handleCanvasPointerUp);
      imageCanvas.addEventListener("pointerleave", resetCanvasCursor);
      imageCanvas.addEventListener("dblclick", deleteMaskAtPoint);
      window.addEventListener("keydown", handleMaskDeleteKey);
      imageUpload.addEventListener("change", async () => {
        const file = imageUpload.files?.[0];
        if (!file) return;

        const objectUrl = URL.createObjectURL(file);
        await setImageSource(objectUrl, file);
        currentImageObjectUrl = objectUrl;
        runImageDetection();
      });
      copyButton.addEventListener("click", async () => {
        await navigator.clipboard.writeText(lastRedacted);
        setStatus("ready", t("copiedTitle"), t("copiedDetail"));
      });
      renderDemos();
      renderImageDemos();
      refreshDynamicText();

      const initialImageDemo = imageDemos[0];
      const initialImageSrc = createDemoImage(initialImageDemo);
      const initialImageReady = setImageSource(initialImageSrc, initialImageSrc, initialImageDemo.id);
      loadModel()
        .then(async () => {
          await initialImageReady;
          if (currentImageInput && !mobileLikeDevice) runImageDetection();
        })
        .catch(() => {});
    </script>
  </body>
</html>
